# ClinDoc-Bench-IN environment template.
# Copy to .env and replace placeholders locally. Do not commit secrets.

USE_LOCAL_MODELS=true
OLLAMA_HOST=http://localhost:11434

# Hugging Face Inference API
HF_TOKEN=hf_xxx
HF_TOKEN_2=hf_xxx

# Gemini API key rotation
GOOGLE_API_KEY=AIza_xxx
GOOGLE_API_KEY_2=AIza_xxx
GOOGLE_API_KEY_3=AIza_xxx
GOOGLE_API_KEY_4=AIza_xxx

# Internal/openai-compatible Qwen3 endpoint
INTERNAL_QWEN3_API_KEY=sk_xxx
INTERNAL_QWEN3_BASE_URL=http://127.0.0.1:4000/v1
INTERNAL_QWEN3_MODEL=qwen3-27b
LOCAL_QWEN3_MOE_API_KEY=sk_xxx

# Optional provider adapters
SARVAM_API_KEY=svm_xxx
DATALAB_API_KEY=datalab_xxx
ZAI_API_KEY=zai_xxx
MISTRAL_API_KEY=mistral_xxx
DEEPSEEK_API_KEY=deepseek_xxx
OPENROUTER_API_KEY=or_xxx

# Optional ontology services
BIOPORTAL_API_KEY=bioportal_xxx
BIOPORTAL_API_URL=https://data.bioontology.org/
ABEROWL_API_URL=https://aber-owl.net/aberowl/rest/labels?query=

# Ground-truth audit override. Keep disabled for normal evaluation.
BENCHMARK_V2_ALLOW_INVALID_GT=0
